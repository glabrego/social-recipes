<div class="page-shell">
  <section class="page-intro page-intro--split">
    <div>
      <p class="eyebrow">Kitchen view</p>
      <h1><%= @kitchen.name %></h1>
      <p class="lede">A focused stream of recipes from this kitchen, designed for scanning and saving.</p>
    </div>
    <div class="info-card">
      <% if user_signed_in? %>
        <%= button_to 'Favoritar', like_kitchen_path(@kitchen), method: :post, class: 'button button--primary' %>
        <%= button_to 'Remover Favorita', like_kitchen_path(@kitchen), method: :delete, class: 'button button--ghost' %>
      <% else %>
        <%= link_to 'Log in to save kitchens', new_user_session_path, class: 'button button--primary' %>
      <% end %>
    </div>
  </section>

  <section class="recipe-grid">
    <% @recipes.each do |recipe| %>
      <%= render recipe %>
    <% end %>
  </section>
</div>
