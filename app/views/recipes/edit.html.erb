<div class="page-shell">
  <section class="page-intro page-intro--split">
    <div>
      <p class="eyebrow">Edit</p>
      <h1>Edit recipe</h1>
      <p class="lede">Update the details, refresh the photo, and keep the recipe clear wherever people read it.</p>
    </div>
    <div class="info-card">
      <p class="eyebrow">Editing tip</p>
      <p>Short ingredient lines and direct instructions make recipes easier to follow on smaller screens.</p>
    </div>
  </section>

  <section class="section-card section-card--form">
    <%= render partial: 'form', locals: { submit_text: 'Save changes' } %>
  </section>
</div>
