<% if flash[:alert].present? %>
  <p class="flash flash--alert"><%= flash[:alert] %></p>
<% end %>

<%= form_with model: @preference, local: true, class: 'editor-form' do |f| %>
  <div class="editor-form__grid">
    <div class="form_group form_group--full">
      <%= f.label :title %>
      <%= f.text_field :title, class: 'form-control' %>
    </div>

    <div class="form_group form_group--full">
      <%= f.submit submit_text, class: 'button button--primary' %>
    </div>
  </div>
<% end %>
