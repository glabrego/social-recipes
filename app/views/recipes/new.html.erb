<div class="page-shell">
  <section class="page-intro page-intro--split">
    <div>
      <p class="eyebrow">Create</p>
      <h1>Add a recipe</h1>
      <p class="lede">Give your recipe a clear title, complete details, and a photo that helps people recognize it at a glance.</p>
    </div>
    <div class="info-card">
      <p class="eyebrow">Helpful recipes are easy to scan</p>
      <p>Keep ingredients concise, steps clear, and metadata complete so the recipe works well on mobile and desktop.</p>
    </div>
  </section>

  <section class="section-card section-card--form">
    <%= render partial: 'form', locals: { submit_text: 'Publish recipe' } %>
  </section>
</div>
