<div class="page-shell">
  <section class="page-intro">
    <p class="eyebrow">Food type</p>
    <h1><%= @foodtype.name %></h1>
    <p class="lede">Recipes collected by the kind of meal they become, with the same calm reading experience as the homepage.</p>
  </section>

  <section class="recipe-grid">
    <% @recipes.each do |recipe| %>
      <%= render recipe %>
    <% end %>
  </section>
</div>
