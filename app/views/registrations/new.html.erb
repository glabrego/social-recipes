<div class="page-shell auth-shell">
  <section class="auth-hero">
    <div>
      <p class="eyebrow">Create account</p>
      <h1>Start a recipe collection that stays easy to use.</h1>
      <p class="lede">Save recipes, follow cuisines, publish your own dishes, and keep everything easy to read from the start.</p>
    </div>
  </section>

  <section class="section-card section-card--form auth-panel">
    <h2>Create account</h2>

    <%= form_with model: resource, scope: resource_name, url: registration_path(resource_name), local: true, class: 'editor-form' do |f| %>
      <%= render 'devise/shared/error_messages', resource: resource %>

      <div class="editor-form__grid">
        <div class="form_group">
          <%= f.label :name %>
          <%= f.text_field :name, autofocus: true, class: 'form-control' %>
        </div>

        <div class="form_group">
          <%= f.label :location %>
          <%= f.text_field :location, class: 'form-control' %>
        </div>

        <div class="form_group">
          <%= f.label :twitter %>
          <%= f.text_field :twitter, class: 'form-control' %>
        </div>

        <div class="form_group">
          <%= f.label :facebook %>
          <%= f.text_field :facebook, class: 'form-control' %>
        </div>

        <div class="form_group form_group--full">
          <%= f.label :email %>
          <%= f.email_field :email, autocomplete: 'email', class: 'form-control' %>
        </div>

        <div class="form_group">
          <%= f.label :password %>
          <% if @minimum_password_length %>
            <span class="form-hint"><%= @minimum_password_length %> characters minimum</span>
          <% end %>
          <%= f.password_field :password, autocomplete: 'new-password', class: 'form-control' %>
        </div>

        <div class="form_group">
          <%= f.label :password_confirmation %>
          <%= f.password_field :password_confirmation, autocomplete: 'new-password', class: 'form-control' %>
        </div>

        <div class="form_group form_group--full">
          <%= f.submit 'Create account', class: 'button button--primary' %>
        </div>
      </div>
    <% end %>

    <%= render 'devise/shared/links' %>
  </section>
</div>
