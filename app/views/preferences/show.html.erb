<div class="page-shell">
  <section class="page-intro">
    <p class="eyebrow">Dietary preference</p>
    <h1><%= @preference.title %></h1>
    <p class="lede">Recipes grouped by the dietary preference they match.</p>
  </section>

  <section class="recipe-grid">
    <% @recipes.each do |recipe| %>
      <%= render recipe %>
    <% end %>
  </section>
</div>
