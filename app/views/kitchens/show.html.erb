<div class="page-shell">
  <section class="page-intro page-intro--split">
    <div>
      <p class="eyebrow">Cuisine</p>
      <h1><%= @kitchen.name %></h1>
      <p class="lede">Browse recipes from this cuisine in one focused, easy-to-scan view.</p>
    </div>
    <div class="info-card">
      <% if user_signed_in? %>
        <%= button_to 'Save cuisine', like_kitchen_path(@kitchen), method: :post, class: 'button button--primary' %>
        <%= button_to 'Remove from saved', like_kitchen_path(@kitchen), method: :delete, class: 'button button--ghost' %>
      <% else %>
        <%= link_to 'Log in to save this cuisine', new_user_session_path, class: 'button button--primary' %>
      <% end %>
    </div>
  </section>

  <section class="recipe-grid">
    <% @recipes.each do |recipe| %>
      <%= render recipe %>
    <% end %>
  </section>
</div>
