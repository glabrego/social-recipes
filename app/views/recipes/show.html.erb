<div class="page-shell">
  <section class="recipe-hero">
    <div class="recipe-hero__visual">
      <%= recipe_visual(@recipe, alt: @recipe.name, class: 'recipe-hero__image') %>
    </div>

    <div class="recipe-hero__copy">
      <p class="eyebrow"><%= @recipe.kitchen.name %> · <%= @recipe.food_type.name %></p>
      <h1><%= @recipe.name %></h1>
      <p class="lede">A <%= @recipe.preference.title.downcase %> recipe that serves <%= @recipe.servings %> and is ready in <%= @recipe.cook_time %> minutes.</p>

      <div class="meta-strip">
        <span class="meta-pill"><strong>Dietary preference</strong><%= @recipe.preference.title %></span>
        <span class="meta-pill"><strong>Difficulty</strong><%= @recipe.difficulty %></span>
        <span class="meta-pill"><strong>Cooking time</strong><%= @recipe.cook_time %> min</span>
        <span class="meta-pill"><strong>Saved</strong><%= saved_count_label(@recipe.fans.count) %></span>
      </div>

      <div class="action-row">
        <% if user_signed_in? %>
          <% if current_user.id == @recipe.user_id %>
            <%= link_to 'Edit recipe', edit_recipe_path(@recipe), class: 'button button--secondary' %>
            <%= button_to 'Delete recipe', recipe_path(@recipe), method: :delete, class: 'button button--ghost' %>
          <% end %>

          <%= button_to 'Save recipe', favorite_recipe_path(@recipe), method: :post, class: 'button button--primary' %>
          <%= button_to 'Remove from saved', favorite_recipe_path(@recipe), method: :delete, class: 'button button--ghost' %>
        <% else %>
          <%= link_to 'Log in to save this recipe', new_user_session_path, class: 'button button--primary' %>
        <% end %>
      </div>
    </div>
  </section>

  <div class="content-layout content-layout--detail">
    <div class="content-stack">
      <section class="section-card">
        <div class="section-card__header">
          <div>
            <p class="eyebrow">What you need</p>
            <h2>Ingredients</h2>
          </div>
        </div>
        <div class="prose-block"><%= simple_format(@recipe.ingredients) %></div>
      </section>

      <section class="section-card">
        <div class="section-card__header">
          <div>
            <p class="eyebrow">How to make it</p>
            <h2>Instructions</h2>
          </div>
        </div>
        <div class="prose-block"><%= simple_format(@recipe.steps) %></div>
      </section>
    </div>

    <aside class="detail-rail">
      <section class="detail-card">
        <p class="eyebrow">Recipe details</p>
        <dl class="detail-list">
          <div>
            <dt>Cuisine</dt>
            <dd><%= link_to @recipe.kitchen.name, @recipe.kitchen %></dd>
          </div>
          <div>
            <dt>Dish type</dt>
            <dd><%= link_to @recipe.food_type.name, @recipe.food_type %></dd>
          </div>
          <div>
            <dt>Dietary preference</dt>
            <dd><%= link_to @recipe.preference.title, @recipe.preference %></dd>
          </div>
          <div>
            <dt>Serves</dt>
            <dd><%= @recipe.servings %></dd>
          </div>
        </dl>
      </section>
    </aside>
  </div>
</div>
