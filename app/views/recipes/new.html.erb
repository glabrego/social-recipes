<div class="page-shell">
  <section class="page-intro page-intro--split">
    <div>
      <p class="eyebrow">Publish</p>
      <h1>Nova receita</h1>
      <p class="lede">Give your recipe a clear title, useful metadata, and a photo that makes people want to keep it.</p>
    </div>
    <div class="info-card">
      <p class="eyebrow">Good submissions feel light</p>
      <p>Keep ingredients scannable, steps short, and metadata complete so the card reads well on mobile.</p>
    </div>
  </section>

  <section class="section-card section-card--form">
    <%= render partial: 'form', locals: { submit_text: 'Criar Receita' } %>
  </section>
</div>
