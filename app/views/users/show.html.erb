<div class="page-shell">
  <section class="profile-hero">
    <div>
      <p class="eyebrow">Profile</p>
      <h1><%= @user.name.presence || @user.email %></h1>
      <p class="lede">A personal space for saved cuisines, saved recipes, and everything this cook has published.</p>
    </div>

    <div class="profile-card">
      <p><strong>Location</strong><%= @user.location.presence || 'Not provided' %></p>
      <p><strong>Email</strong><%= @user.email %></p>
      <p><strong>X / Twitter</strong><%= @user.twitter.presence || 'Not provided' %></p>
      <p><strong>Facebook</strong><%= @user.facebook.presence || 'Not provided' %></p>
    </div>
  </section>

  <div class="content-stack">
    <section class="section-card">
      <div class="section-card__header">
        <div>
          <p class="eyebrow">Saved cuisines</p>
          <h2>Saved cuisines</h2>
        </div>
      </div>
      <div class="taxonomy-grid taxonomy-grid--compact">
        <%= render @user.likes %>
      </div>
    </section>

    <section class="section-card">
      <div class="section-card__header">
        <div>
          <p class="eyebrow">Saved recipes</p>
          <h2>Saved recipes</h2>
        </div>
      </div>
      <div class="recipe-grid">
        <%= render @user.favorites %>
      </div>
    </section>

    <section class="section-card">
      <div class="section-card__header">
        <div>
          <p class="eyebrow">Published</p>
          <h2>Published recipes</h2>
        </div>
      </div>
      <div class="recipe-grid">
        <%= render @user.recipes %>
      </div>
    </section>
  </div>
</div>
