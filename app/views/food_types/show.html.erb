<div class="page-shell">
  <section class="page-intro">
    <p class="eyebrow">Dish type</p>
    <h1><%= @foodtype.name %></h1>
    <p class="lede">Recipes grouped by the kind of dish they become.</p>
  </section>

  <section class="recipe-grid">
    <% @recipes.each do |recipe| %>
      <%= render recipe %>
    <% end %>
  </section>
</div>
