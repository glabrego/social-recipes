<article class="recipe-card">
  <%= link_to recipe_path(recipe), class: 'recipe-card__visual-link' do %>
    <%= recipe_visual(recipe, alt: recipe.name, class: 'recipe-card__visual') %>
  <% end %>

  <div class="recipe-card__body">
    <p class="eyebrow"><%= recipe.kitchen.name %> · <%= recipe.food_type.name %></p>
    <h3 class="recipe-card__title"><%= link_to recipe.name, recipe %></h3>
    <p class="recipe-card__meta">
      <span><%= recipe.preference.title %></span>
      <span><%= recipe.difficulty %></span>
    </p>
    <div class="recipe-card__footer">
      <span><%= saved_count_label(recipe.fans.count) %></span>
      <span><%= recipe.cook_time %> min</span>
    </div>
  </div>
</article>
