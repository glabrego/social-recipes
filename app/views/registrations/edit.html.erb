<div class="page-shell">
  <section class="page-intro page-intro--split">
    <div>
      <p class="eyebrow">Account settings</p>
      <h1>Refine your profile without losing the calm.</h1>
      <p class="page-intro__body">Update your public details, refresh your password, or close the account if you no longer need it.</p>
    </div>

    <aside class="info-card">
      <p class="eyebrow">Profile care</p>
      <h3>Keep your details current</h3>
      <p>Your profile powers saved kitchens, published recipes, and the reading rhythm of the app.</p>
    </aside>
  </section>

  <section class="section-card section-card--form">
    <h2>Edit <%= resource_name.to_s.humanize %></h2>

    <%= form_with model: resource, scope: resource_name, url: registration_path(resource_name), method: :put, local: true, class: 'editor-form' do |f| %>
      <%= render 'devise/shared/error_messages', resource: resource %>

      <div class="editor-form__grid">
        <div class="form_group">
          <%= f.label :name %>
          <%= f.text_field :name, autofocus: true, class: 'form-control' %>
        </div>

        <div class="form_group">
          <%= f.label :location %>
          <%= f.text_field :location, class: 'form-control' %>
        </div>

        <div class="form_group">
          <%= f.label :twitter %>
          <%= f.text_field :twitter, class: 'form-control' %>
        </div>

        <div class="form_group">
          <%= f.label :facebook %>
          <%= f.text_field :facebook, class: 'form-control' %>
        </div>

        <div class="form_group form_group--full">
          <%= f.label :email %>
          <%= f.email_field :email, autocomplete: 'email', class: 'form-control' %>
        </div>

        <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
          <p class="flash flash--notice">Currently waiting confirmation for: <%= resource.unconfirmed_email %></p>
        <% end %>

        <div class="form_group">
          <%= f.label :password %>
          <span class="form-hint">Leave blank if you do not want to change it</span>
          <%= f.password_field :password, autocomplete: 'new-password', class: 'form-control' %>
        </div>

        <div class="form_group">
          <%= f.label :password_confirmation %>
          <%= f.password_field :password_confirmation, autocomplete: 'new-password', class: 'form-control' %>
        </div>

        <div class="form_group form_group--full">
          <%= f.label :current_password %>
          <span class="form-hint">We need your current password to confirm these changes</span>
          <%= f.password_field :current_password, autocomplete: 'current-password', class: 'form-control' %>
        </div>

        <div class="form_group form_group--full">
          <%= f.submit 'Update', class: 'button button--primary' %>
        </div>
      </div>
    <% end %>

    <hr>

    <div class="content-stack">
      <div>
        <p class="eyebrow">Account removal</p>
        <h3>Cancel my account</h3>
        <p class="page-intro__body">This permanently removes your access to saved recipes and profile actions.</p>
      </div>

      <div class="action-row">
        <%= button_to 'Cancel my account', registration_path(resource_name), method: :delete, data: { turbo_confirm: 'Are you sure?' }, class: 'button button--ghost' %>
        <%= link_to 'Back to profile', user_path(resource), class: 'button button--secondary' %>
      </div>
    </div>
  </section>
</div>
