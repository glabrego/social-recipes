<div class="page-shell">
  <section class="page-intro">
    <p class="eyebrow">Preference</p>
    <h1><%= @preference.title %></h1>
    <p class="lede">A curated view of recipes organized around the way someone wants to eat.</p>
  </section>

  <section class="recipe-grid">
    <% @recipes.each do |recipe| %>
      <%= render recipe %>
    <% end %>
  </section>
</div>
