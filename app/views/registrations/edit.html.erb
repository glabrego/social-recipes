<div class="page-shell">
  <section class="page-intro page-intro--split">
    <div>
      <p class="eyebrow">Account settings</p>
      <h1>Update your profile and account details.</h1>
      <p class="page-intro__body">Change your public profile, update your password, or close your account if you no longer need it.</p>
    </div>

    <aside class="info-card">
      <p class="eyebrow">Keep it current</p>
      <h3>Make your profile easier to recognize</h3>
      <p>Your profile powers your saved recipes, saved cuisines, and published dishes.</p>
    </aside>
  </section>

  <section class="section-card section-card--form">
    <h2>Edit account</h2>

    <%= form_with model: resource, scope: resource_name, url: registration_path(resource_name), method: :put, local: true, class: 'editor-form' do |f| %>
      <%= render 'devise/shared/error_messages', resource: resource %>

      <div class="editor-form__grid">
        <div class="form_group">
          <%= f.label :name %>
          <%= f.text_field :name, autofocus: true, class: 'form-control' %>
        </div>

        <div class="form_group">
          <%= f.label :location %>
          <%= f.text_field :location, class: 'form-control' %>
        </div>

        <div class="form_group">
          <%= f.label :twitter %>
          <%= f.text_field :twitter, class: 'form-control' %>
        </div>

        <div class="form_group">
          <%= f.label :facebook %>
          <%= f.text_field :facebook, class: 'form-control' %>
        </div>

        <div class="form_group form_group--full">
          <%= f.label :email %>
          <%= f.email_field :email, autocomplete: 'email', class: 'form-control' %>
        </div>

        <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
          <p class="flash flash--notice">Waiting for email confirmation: <%= resource.unconfirmed_email %></p>
        <% end %>

        <div class="form_group">
          <%= f.label :password %>
          <span class="form-hint">Leave blank if you want to keep your current password</span>
          <%= f.password_field :password, autocomplete: 'new-password', class: 'form-control' %>
        </div>

        <div class="form_group">
          <%= f.label :password_confirmation %>
          <%= f.password_field :password_confirmation, autocomplete: 'new-password', class: 'form-control' %>
        </div>

        <div class="form_group form_group--full">
          <%= f.label :current_password %>
          <span class="form-hint">Enter your current password to save these changes</span>
          <%= f.password_field :current_password, autocomplete: 'current-password', class: 'form-control' %>
        </div>

        <div class="form_group form_group--full">
          <%= f.submit 'Save changes', class: 'button button--primary' %>
        </div>
      </div>
    <% end %>

    <hr>

    <div class="content-stack">
      <div>
        <p class="eyebrow">Close account</p>
        <h3>Delete my account</h3>
        <p class="page-intro__body">This permanently removes your account access, saved recipes, and profile actions.</p>
      </div>

      <div class="action-row">
        <%= button_to 'Delete account', registration_path(resource_name), method: :delete, data: { turbo_confirm: 'Are you sure?' }, class: 'button button--ghost' %>
        <%= link_to 'Back to profile', user_path(resource), class: 'button button--secondary' %>
      </div>
    </div>
  </section>
</div>
