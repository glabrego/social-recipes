<span class="error_message"><%= flash[:alert] %></span>
<%= form_with model: @recipe, local: true, html: { multipart: true, class: 'editor-form' } do |f| %>
  <div class="editor-form__grid">
  <div class="form_group form_group--full">
    <%= f.label :name %>
    <%= f.text_field :name, class: 'form-control' %>
  </div>
  <div class="form_group">
    <%= f.label :kitchen_id %>
    <%= f.collection_select :kitchen_id, @kitchens, :id, :name, { prompt: 'Select a cuisine' }, { class: 'form-control' } %>
  </div>
  <div class="form_group">
    <%= f.label :food_type_id %>
    <%= f.collection_select :food_type_id, @food_types, :id, :name, { prompt: 'Select a dish type' }, { class: 'form-control' } %>
  </div>
  <div class="form_group">
    <%= f.label :preference_id %>
    <%= f.collection_select :preference_id, @preferences, :id, :title, { prompt: 'Select a dietary preference' }, { class: 'form-control' } %>
  </div>
  <div class="form_group">
    <%= f.label :servings %>
    <%= f.text_field :servings, class: 'form-control' %>
  </div>
  <div class="form_group">
    <%= f.label :cook_time %>
    <%= f.text_field :cook_time, class: 'form-control' %>
  </div>
  <div class="form_group">
    <%= f.label :difficulty %>
    <%= f.select :difficulty, options_for_select(Recipe::DIFFICULTY_OPTIONS, @recipe.difficulty), { prompt: 'Select a difficulty level' }, { class: 'form-control' } %>
  </div>
  <div class="form_group">
    <%= f.label :ingredients %>
    <%= f.text_area :ingredients, class: 'form-control' %>
  </div>
  <div class="form_group">
    <%= f.label :steps %>
    <%= f.text_area :steps, class: 'form-control' %>
  </div>
  <div class="form_group form_group--full">
    <%= f.label :photo %>
    <%= f.file_field :photo, class: 'form-control upload' %>
    <div class="image-frame"></div>
  </div>
  <div class="form_group form_group--full">
    <%= f.submit submit_text, class: 'button button--primary' %>
  </div>
  </div>
<% end %>
