<div class="page-shell">
  <section class="hero-panel hero-panel--home">
    <div class="hero-panel__copy">
      <p class="eyebrow">Simple tools for everyday cooking</p>
      <h1>Save recipes you will actually want to cook again.</h1>
      <p class="lede">Browse popular dishes, filter by cuisine and dietary preference, and build a personal recipe collection that stays easy to scan.</p>
      <div class="hero-panel__actions">
        <%= link_to 'Browse recipes', recipes_path, class: 'button button--primary' %>
        <% if user_signed_in? %>
          <%= link_to 'Add a recipe', new_recipe_path, class: 'button button--secondary' %>
        <% else %>
          <%= link_to 'Create account', new_user_registration_path, class: 'button button--secondary' %>
        <% end %>
      </div>
    </div>

    <div class="hero-metrics">
      <div class="metric-card">
        <span class="metric-card__label">Top picks</span>
        <strong><%= @favorites.size %></strong>
      </div>
      <div class="metric-card">
        <span class="metric-card__label">Recently added</span>
        <strong><%= @recipes.size %></strong>
      </div>
      <div class="metric-card">
        <span class="metric-card__label">Filter groups</span>
        <strong><%= @kitchens.size + @food_types.size + @preferences.size %></strong>
      </div>
    </div>
  </section>

  <div class="content-layout">
    <div class="content-stack">
      <section class="section-card">
        <div class="section-card__header">
          <div>
            <p class="eyebrow">Most saved</p>
            <h2>Saved recipes</h2>
          </div>
          <p class="section-card__hint">Recipes people return to and save for later.</p>
        </div>

        <div class="recipe-grid">
          <% if @favorites.any? %>
            <% @favorites.each do |recipe| %>
              <%= render recipe %>
            <% end %>
          <% else %>
            <div class="empty-state">
              No recipes have been saved yet. Save one to start this list.
            </div>
          <% end %>
        </div>
      </section>

      <section class="section-card">
        <div class="section-card__header">
          <div>
            <p class="eyebrow">Fresh additions</p>
            <h2>Recently added</h2>
          </div>
          <p class="section-card__hint">The latest recipes added to the collection.</p>
        </div>

        <div class="recipe-grid">
          <% if @recipes.any? %>
            <% @recipes.each do |recipe| %>
              <%= render recipe %>
            <% end %>
          <% else %>
            <div class="empty-state">
              No recipes have been published yet. Add the first recipe to get started.
            </div>
          <% end %>
        </div>
      </section>
    </div>

    <aside class="filter-rail">
      <section class="filter-card">
        <p class="eyebrow">Find recipes faster</p>
        <h3>Browse by</h3>

        <div class="filter-group">
          <h4>Cuisines</h4>
          <div class="tag-cloud">
            <% @kitchens.each do |kitchen| %>
              <%= link_to kitchen.name, kitchen_path(kitchen), class: 'tag-link' %>
            <% end %>
          </div>
        </div>

        <div class="filter-group">
          <h4>Dish types</h4>
          <div class="tag-cloud">
            <% @food_types.each do |food_type| %>
              <%= link_to food_type.name, food_type_path(food_type), class: 'tag-link' %>
            <% end %>
          </div>
        </div>

        <div class="filter-group">
          <h4>Dietary preferences</h4>
          <div class="tag-cloud">
            <% @preferences.each do |preference| %>
              <%= link_to preference.title, preference_path(preference), class: 'tag-link' %>
            <% end %>
          </div>
        </div>
      </section>
    </aside>
  </div>
</div>
